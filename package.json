{
    "name": "8-sprint-mission-be",
    "version": "1.0.0",
    "description": "> _이 저장소는 판다마켓 프로젝트의 백엔드 코드를 관리하는 곳입니다. 프로젝트를 클론하여 개발 환경을 설정하고, 각 브랜치에서 해당 스프린트 미션을 수행해 주세요!_ 🛠️",
    "main": "index.js",
    "scripts": {
        "setup": "npm i && npm run frontinstall && npm run backinstall",
        "frontinstall": "cd frontend && npm i",
        "backinstall": "cd backend/prisma_back && npm i",
        "front": "cd frontend && npm run dev",
        "back": "cd backend/prisma_back && npm run dev",
        "studio": "cd backend/prisma_back && npx prisma studio",
        "migrate": "cd backend/prisma_back && npx prisma migrate deploy && npx prisma generate",
        "seed": "cd backend/prisma_back && npm run seed",
        "build": "cd frontend && npm run build",
        "start": "concurrently \"npm run backstart\" \"npm run frontstart\"",
        "frontstart": "cd frontend && npm run start",
        "backstart": "cd backend/prisma_back && node app.js",
        "deploy": "npm run setup && npm run migrate && npm run build"   
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/HwSoonDev/8-sprint-mission-be.git"
    },
    "author": "",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/HwSoonDev/8-sprint-mission-be/issues"
    },
    "homepage": "https://github.com/HwSoonDev/8-sprint-mission-be#readme",
    "dependencies": {
        "concurrently": "^9.2.1"
    }
}
