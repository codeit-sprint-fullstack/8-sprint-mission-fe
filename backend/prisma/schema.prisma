generator client {
  provider = "prisma-client-js"
  //output   = "../generated/prisma" 
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String  @id @default(uuid())
  providerId String? @unique
  provider   String  @default("local")

  email        String  @unique
  name         String
  password     String?
  refreshToken String?

  products Product[]
  articles Article[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id            String    @id @default(uuid())
  name          String
  price         Int
  description   String
  userName      String    @default("익명 판다")
  tags          String[]
  images        String[]
  favoriteCount Int       @default(0)
  comment       Comment[]

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Article {
  id            String    @id @default(uuid())
  title         String
  content       String
  userName      String    @default("익명 판다")
  favoriteCount Int       @default(0)
  comment       Comment[]

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  userName  String   @default("익명 판다")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //onDlete 설정 - Cascade 상위 항목 삭제시 같이 삭제 (게시글이 사라지면 댓글도 사라집니다.)
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  productId String?
  articleId String?
}
